// Constantes
const int MAX_ITERACOES = 100;
const float PRECISAO = 0.0001;

// Função para calcular fatorial
func fatorial(int n) {
    if (n <= 1) {
        return 1;
    } else {
        return n * fatorial(n - 1);
    }
}

// Função para verificar número primo
func eh_primo(int numero) {
    int i = 2;
    bool primo = true;
    
    while (i < numero) {
        if (numero % i == 0) {
            primo = false;
            break;
        }
        i++;
    }
    
    return primo;
}

